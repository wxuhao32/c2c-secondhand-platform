# ============================================
# C2C二手交易平台 - 环境变量配置模板
# 复制此文件为 .env 并修改为实际值
# ============================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_DATABASE=resale_platform
MYSQL_USER=resale
MYSQL_PASSWORD=your_secure_mysql_password
MYSQL_PORT=3306

# Redis 配置
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置（生产环境必须修改为随机强密钥）
# 建议使用: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_must_be_at_least_64_characters_long_for_hs512_algorithm

# 后端服务配置
BACKEND_PORT=10000
SERVER_PORT=10000

# 前端服务配置
FRONTEND_PORT=80
FRONTEND_HTTPS_PORT=443

# Prometheus 配置
PROMETHEUS_PORT=9090

# Grafana 配置
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password
